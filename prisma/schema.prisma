generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id
  username     String        @unique
  passwordHash String        @map("password_hash")
  name         String
  avatar       String        @default("👤")
  createdAt    DateTime      @default(now()) @map("created_at")
  watchlist    Watchlist[]
  chatSessions ChatSession[]

  @@map("users")
}

model ChatSession {
  id        String        @id
  userId    String        @map("user_id")
  title     String        @default("新对话")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id
  sessionId String      @map("session_id")
  role      String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model Watchlist {
  id      String   @id
  userId  String   @map("user_id")
  code    String
  type    String
  addedAt DateTime @default(now()) @map("added_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, code, type])
  @@map("watchlist")
}

model BigVAuthor {
  id        String        @id
  name      String        @unique
  slug      String        @unique
  avatar    String?       @default("🧠")
  category  String        @default("综合研判")
  bio       String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  articles  BigVArticle[]

  @@map("bigv_authors")
}

model BigVArticle {
  id              String     @id
  authorId        String     @map("author_id")
  title           String
  content         String
  images          String[]   @default([])
  sourceUrl       String?    @map("source_url")
  publishedAt     DateTime   @map("published_at")
  expiresAt       DateTime   @map("expires_at")
  summary         String
  primaryCategory String     @map("primary_category")
  tags            String[]   @default([])
  sentiment       String     @default("neutral")
  score           Int        @default(0)
  rankScore       Float      @default(0) @map("rank_score")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  author          BigVAuthor @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([publishedAt(sort: Desc)])
  @@index([primaryCategory])
  @@index([authorId, publishedAt(sort: Desc)])
  @@map("bigv_articles")
}
