generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String                  @id
  username           String                  @unique
  passwordHash       String                  @map("password_hash")
  name               String
  avatar             String                  @default("👤")
  createdAt          DateTime                @default(now()) @map("created_at")
  watchlist          Watchlist[]
  chatSessions       ChatSession[]
  investmentProfile  UserInvestmentProfile?
  watchlistTheses    WatchlistThesis[]
  analysisSnapshots  AnalysisSnapshot[]

  @@map("users")
}

model ChatSession {
  id        String        @id
  userId    String        @map("user_id")
  title     String        @default("新对话")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id
  sessionId String      @map("session_id")
  role      String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model Watchlist {
  id      String   @id
  userId  String   @map("user_id")
  code    String
  type    String
  addedAt DateTime @default(now()) @map("added_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, code, type])
  @@map("watchlist")
}

model UserInvestmentProfile {
  id                      String   @id
  userId                  String   @unique @map("user_id")
  riskPreference          String   @default("balanced") @map("risk_preference")
  investmentStyle         String[] @default([]) @map("investment_style")
  holdingPeriodPreference String?  @map("holding_period_preference")
  preferredEvidence       String[] @default([]) @map("preferred_evidence")
  dislikedPatterns        String[] @default([]) @map("disliked_patterns")
  summary                 String?
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_investment_profiles")
}

model WatchlistThesis {
  id                     String   @id
  userId                 String   @map("user_id")
  code                   String
  market                 Int      @default(1)
  type                   String   @default("stock")
  name                   String?
  watchReason            String   @default("") @map("watch_reason")
  bullPoints             String[] @default([]) @map("bull_points")
  bearPoints             String[] @default([]) @map("bear_points")
  watchSignals           String[] @default([]) @map("watch_signals")
  invalidationConditions String[] @default([]) @map("invalidation_conditions")
  lastJudgement          String?  @map("last_judgement")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code, type])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("watchlist_theses")
}

model AnalysisSnapshot {
  id          String   @id
  userId      String   @map("user_id")
  code        String?
  market      Int?
  type        String   @default("stock")
  title       String
  summary     String
  bullPoints  String[] @default([]) @map("bull_points")
  bearPoints  String[] @default([]) @map("bear_points")
  keyChange   String?  @map("key_change")
  confidence  Float?
  sourceType  String   @default("manual") @map("source_type")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("analysis_snapshots")
}

model BigVAuthor {
  id        String        @id
  name      String        @unique
  slug      String        @unique
  avatar    String?       @default("🧠")
  category  String        @default("综合研判")
  bio       String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  articles  BigVArticle[]

  @@map("bigv_authors")
}

model BigVArticle {
  id              String     @id
  authorId        String     @map("author_id")
  title           String
  content         String
  images          String[]   @default([])
  sourceUrl       String?    @map("source_url")
  publishedAt     DateTime   @map("published_at")
  expiresAt       DateTime   @map("expires_at")
  summary         String
  primaryCategory String     @map("primary_category")
  tags            String[]   @default([])
  sentiment       String     @default("neutral")
  score           Int        @default(0)
  rankScore       Float      @default(0) @map("rank_score")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  author          BigVAuthor @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([publishedAt(sort: Desc)])
  @@index([primaryCategory])
  @@index([authorId, publishedAt(sort: Desc)])
  @@map("bigv_articles")
}
